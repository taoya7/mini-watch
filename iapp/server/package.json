{
  "name": "hono-app-single",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.4",
  "description": "",
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "dist/front-dist/**/*"
    ],
    "outputPath": "dist"
  },
  "author": "",
  "license": "ISC",
  "keywords": [],
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "NODE_ENV=development PORT=3001 tsx watch src/index.tsx",
    "dev:client": "vite --clearScreen false --strictPort",
    "start": "node dist/index.js",
    "build": "tsc && tsc-alias --resolve-full-paths",
    "build:client": "vite build",
    "bundle": "pnpm build:client && tsx scripts/build.ts",
    "build:binary:linux": "pnpm bundle && pkg dist/bundle.cjs --targets node20-linux-x64 --output dist/server-x86_64-unknown-linux-gnu --options expose-gc",
    "build:binary:windows": "pnpm bundle && pkg dist/bundle.cjs --targets node20-win-x64 --output dist/server-x86_64-pc-windows-msvc.exe --options expose-gc",
    "build:binary:mac-intel": "pnpm bundle && pkg dist/bundle.cjs --targets node20-macos-x64 --output dist/server-x86_64-apple-darwin --options expose-gc",
    "build:binary:mac-arm": "pnpm bundle && pkg dist/bundle.cjs --targets node20-macos-arm64 --output dist/server-aarch64-apple-darwin --options expose-gc",
    "build:binary:all": "pnpm run build:binary:linux && pnpm run build:binary:windows && pnpm run build:binary:mac-intel && pnpm run build:binary:mac-arm",
    "postinstall": "node scripts/postinstall.js",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit -p tsconfig.client.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.2.0",
    "@hono/standard-validator": "^0.2.2",
    "@tailwindcss/vite": "^4.3.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.21",
    "hono-openapi": "^1.3.0",
    "lucide-vue-next": "^1.0.0",
    "nanoid": "^5.1.11",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.7",
    "rotating-file-stream": "^3.2.9",
    "systeminformation": "^5.23.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "unstorage": "^1.17.5",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@yao-pkg/pkg": "^6.19.0",
    "concurrently": "^9.2.1",
    "dayjs": "^1.11.20",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^1.5.0",
    "jiti": "^2.7.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.1.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.14",
    "vite-plugin-html": "^3.2.2",
    "vue-tsc": "^3.3.1"
  }
}
